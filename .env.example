# Database
DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://username:password@host:5432/database?sslmode=require

# Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Auth / Sessions
SESSION_SECRET=replace-with-long-random-secret

# Email
RESEND_API_KEY=re_...
RESEND_FROM="EdgeRent <noreply@yourdomain.com>"

# App URLs
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# License flags
LICENSE_STATUS=ACTIVE
LICENSE_MESSAGE=Your license has been suspended. Please contact support.

# Tenant branding / metadata
TENANT_NAME="EdgeRent Lite"
TENANT_LOGO_URL="/logo.svg"
TENANT_PRIMARY_COLOR="#2563eb"
TENANT_PHONE="+599 700 0000"
TENANT_WHATSAPP="+599 700 0000"
TENANT_WHATSAPP_URL="https://wa.me/5997000000"
TENANT_FACEBOOK_URL=""
TENANT_INSTAGRAM_URL=""
TENANT_LINKEDIN_URL=""
TENANT_TIKTOK_URL=""
TENANT_EMAIL="contact@yourdomain.com"
TENANT_ADDRESS="Kaya Example 100, Kralendijk, Bonaire"
TENANT_CURRENCY="USD"
TENANT_PAYMENT_INSTRUCTIONS="Please pay by bank transfer or card and include your booking code in the payment reference."
TENANT_TERMS_PDF_URL="/terms.pdf"

# Defaults (used when settings table has no value yet)
DEFAULT_TAX_PERCENTAGE=0
DEFAULT_MIN_BOOKING_DAYS=1
