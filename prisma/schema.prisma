// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(OWNER)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  auditLogs     AuditLog[]

  @@index([email])
}

enum Role {
  ROOT
  OWNER
  STAFF
}

model Vehicle {
  id            String    @id @default(cuid())
  name          String
  plateNumber   String?   @unique
  imageUrl      String?
  categoryId    String
  category      VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  seats         Int       @default(5)
  transmission  TransmissionType @default(AUTOMATIC)
  hasAC         Boolean   @default(true)
  dailyRate     Int       // stored in cents
  status        VehicleStatus @default(ACTIVE)
  notes         String?
  createdAt     DateTime  @default(now())
  bookings      Booking[]

  @@index([status])
  @@index([categoryId])
}

model Location {
  id             String    @id @default(cuid())
  name           String
  code           String?   @unique
  address        String?
  createdAt      DateTime  @default(now())
  pickupBookings Booking[] @relation("PickupLocation")
  dropoffBookings Booking[] @relation("DropoffLocation")
}

enum VehicleStatus {
  ACTIVE
  ON_RENT
  MAINTENANCE
  INACTIVE
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
}

model VehicleCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  seats       Int       @default(5)
  transmission TransmissionType @default(AUTOMATIC)
  hasAC       Boolean   @default(true)
  dailyRate   Int       // stored in cents
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  vehicles    Vehicle[]
  bookings    Booking[]

  @@index([isActive])
  @@index([sortOrder])
}

model Booking {
  id                  String    @id @default(cuid())
  categoryId          String
  category            VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vehicleId           String?
  vehicle             Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customerName        String
  customerEmail       String
  customerPhone       String
  birthDate           DateTime?
  driverLicenseNumber String?
  licenseExpiryDate   DateTime?
  driverLicenseUrl    String?
  startDate           DateTime
  endDate             DateTime  // treated as exclusive end date for overlap logic
  pickupLocationId    String?
  pickupLocationRef   Location? @relation("PickupLocation", fields: [pickupLocationId], references: [id], onDelete: SetNull)
  dropoffLocationId   String?
  dropoffLocationRef  Location? @relation("DropoffLocation", fields: [dropoffLocationId], references: [id], onDelete: SetNull)
  pickupLocation      String?
  dropoffLocation     String?
  totalAmount         Int       // stored in cents
  status              BookingStatus @default(PENDING)
  bookingCode         String    @unique
  holdExpiresAt       DateTime  @default(dbgenerated("(now() + '02:00:00'::interval)"))
  paymentProofUrl     String?
  paymentReceivedAt   DateTime?
  termsAcceptedAt     DateTime?
  notes               String?
  invoiceUrl          String?
  createdAt           DateTime  @default(now())
  bookingExtras       BookingExtra[]
  bookingDiscount     BookingDiscount?
  review              Review?
  auditLogs           AuditLog[]

  @@index([vehicleId, startDate, endDate])
  @@index([categoryId, startDate, endDate])
  @@index([pickupLocationId])
  @@index([dropoffLocationId])
  @@index([status])
  @@index([bookingCode])
  @@index([createdAt])
  adminUsers AdminUser[]
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @db.Timestamp(6)
}

model Review {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingCode  String
  customerName String
  rating       Int
  comment      String
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([isVisible, createdAt])
  @@index([bookingCode])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
}

model AuditLog {
  id            String    @id @default(cuid())
  adminUserId   String
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  action        String
  bookingId     String?
  booking       Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([adminUserId])
  @@index([createdAt])
}

enum ExtraPricingType {
  DAILY
  FLAT
}

model Extra {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  pricingType ExtraPricingType @default(FLAT)
  amount      Int
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  bookingExtras BookingExtra[]

  @@index([isActive])
}

model BookingExtra {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extraId    String
  extra      Extra    @relation(fields: [extraId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  lineTotal  Int
  createdAt  DateTime @default(now())

  @@unique([bookingId, extraId])
  @@index([bookingId])
  @@index([extraId])
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  percentage  Int
  isActive    Boolean  @default(true)
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  bookings    BookingDiscount[]
}

model BookingDiscount {
  id             String       @id @default(cuid())
  bookingId      String       @unique
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Restrict)
  percentage     Int
  amount         Int
  createdAt      DateTime     @default(now())

  @@index([discountCodeId])
}
