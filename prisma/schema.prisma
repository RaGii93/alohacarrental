// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  role          Role      @default(OWNER)
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  auditLogs     AuditLog[]
  maintenanceRecordsCreated VehicleMaintenanceRecord[] @relation("MaintenanceRecordCreatedBy")
  inventoryTransactionsCreated InventoryTransaction[] @relation("InventoryTransactionCreatedBy")
  odometerLogsCreated VehicleOdometerLog[] @relation("VehicleOdometerLogCreatedBy")
  vehicleAttachmentsUploaded VehicleAttachment[] @relation("VehicleAttachmentUploadedBy")
  vehicleUnavailabilityCreated VehicleUnavailabilityRecord[] @relation("VehicleUnavailabilityCreatedBy")
  notificationsCreated Notification[] @relation("NotificationCreatedBy")

  @@index([email])
}

enum Role {
  ROOT
  OWNER
  STAFF
}

model Vehicle {
  id            String    @id @default(cuid())
  name          String
  plateNumber   String?   @unique
  imageUrl      String?
  categoryId    String
  category      VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  seats         Int       @default(5)
  transmission  TransmissionType @default(AUTOMATIC)
  hasAC         Boolean   @default(true)
  dailyRate     Int       // stored in cents
  status        VehicleStatus @default(ACTIVE)
  currentOdometerKm Int?
  purchaseDate  DateTime?
  purchasePrice Int?
  insurancePolicyNumber String?
  insuranceProviderName String?
  insuranceStartDate DateTime?
  insuranceEndDate DateTime?
  inspectionDate DateTime?
  inspectionExpiryDate DateTime?
  insuranceNotes String?
  inspectionNotes String?
  notes         String?
  createdAt     DateTime  @default(now())
  bookings      Booking[]
  blockouts     VehicleBlockout[]
  maintenanceRecords VehicleMaintenanceRecord[]
  odometerLogs VehicleOdometerLog[]
  insuranceRecords VehicleInsuranceRecord[]
  inspectionRecords VehicleInspectionRecord[]
  attachments VehicleAttachment[]
  unavailabilityRecords VehicleUnavailabilityRecord[]
  inventoryTransactions InventoryTransaction[]

  @@index([status])
  @@index([categoryId])
  @@index([insuranceEndDate])
  @@index([inspectionExpiryDate])
}

model Location {
  id             String    @id @default(cuid())
  name           String
  code           String?   @unique
  address        String?
  createdAt      DateTime  @default(now())
  pickupBookings Booking[] @relation("PickupLocation")
  dropoffBookings Booking[] @relation("DropoffLocation")
}

model VehicleBlockout {
  id          String    @id @default(cuid())
  vehicleId   String?
  vehicle     Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  startDate   DateTime
  endDate     DateTime
  note        String?
  createdAt   DateTime  @default(now())

  @@index([vehicleId, startDate, endDate])
  @@index([startDate, endDate])
}

enum VehicleStatus {
  ACTIVE
  ON_RENT
  MAINTENANCE
  INACTIVE
}

enum TransmissionType {
  AUTOMATIC
  MANUAL
}

model VehicleCategory {
  id          String    @id @default(cuid())
  name        String    @unique
  description String?
  imageUrl    String?
  seats       Int       @default(5)
  transmission TransmissionType @default(AUTOMATIC)
  hasAC       Boolean   @default(true)
  hasCarPlay  Boolean   @default(false)
  hasBackupCamera Boolean @default(false)
  dailyRate   Int       // stored in cents
  fuelChargePerQuarter Int @default(2500) // stored in cents
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  vehicles    Vehicle[]
  bookings    Booking[]
  features    VehicleCategoryFeature[]
  maintenanceTemplates MaintenanceTemplate[]

  @@index([isActive])
  @@index([sortOrder])
}

enum MaintenanceTemplateType {
  SMALL
  BIG
  CUSTOM
}

enum VehicleMaintenanceServiceType {
  SMALL
  BIG
  CUSTOM
  REPAIR
  INSPECTION_PREP
  INSURANCE_RELATED
}

enum VehicleMaintenanceCategoryKind {
  MAINTENANCE
  REPAIR
  TIRES
  BATTERY
  AC
  BRAKES
  ENGINE
  SUSPENSION
  BODYWORK
  ELECTRICAL
  INSPECTION
  INSURANCE
  OTHER
}

enum InventoryTransactionType {
  PURCHASE
  USAGE
  ADJUSTMENT
  RETURN
}

enum OdometerLogSource {
  MANUAL_UPDATE
  BOOKING_RETURN
  MAINTENANCE
  IMPORT
}

enum VehicleUnavailabilityType {
  MAINTENANCE
  REPAIR
  INSPECTION
  INSURANCE_HOLD
  MANUAL
}

model MaintenanceTemplate {
  id            String   @id @default(cuid())
  name          String
  type          MaintenanceTemplateType
  description   String?
  intervalKm    Int?
  isActive      Boolean  @default(true)
  appliesToVehicleCategoryId String?
  appliesToVehicleCategory VehicleCategory? @relation(fields: [appliesToVehicleCategoryId], references: [id], onDelete: SetNull)
  parts         MaintenanceTemplatePart[]
  records       VehicleMaintenanceRecord[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@index([type])
  @@index([appliesToVehicleCategoryId])
}

model MaintenanceTemplatePart {
  id                   String   @id @default(cuid())
  maintenanceTemplateId String
  maintenanceTemplate  MaintenanceTemplate @relation(fields: [maintenanceTemplateId], references: [id], onDelete: Cascade)
  inventoryPartId      String
  inventoryPart        InventoryPart @relation(fields: [inventoryPartId], references: [id], onDelete: Cascade)
  quantityRequired     Float
  notes                String?

  @@index([maintenanceTemplateId])
  @@index([inventoryPartId])
}

model VehicleMaintenanceRecord {
  id                  String   @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceTemplateId String?
  maintenanceTemplate MaintenanceTemplate? @relation(fields: [maintenanceTemplateId], references: [id], onDelete: SetNull)
  serviceType         VehicleMaintenanceServiceType
  title               String
  description         String?
  serviceDate         DateTime
  odometerKm          Int?
  nextDueKm           Int?
  vendorName          String?
  invoiceNumber       String?
  laborCost           Int      @default(0)
  partsCost           Int      @default(0)
  totalCost           Int      @default(0)
  maintenanceCategory VehicleMaintenanceCategoryKind?
  isIncidentRelated   Boolean  @default(false)
  notes               String?
  createdByUserId     String?
  createdByUser       AdminUser? @relation("MaintenanceRecordCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  partUsages          VehicleMaintenancePartUsage[]
  attachments         VehicleAttachment[]
  downtimeRecords     VehicleUnavailabilityRecord[]
  inventoryTransactions InventoryTransaction[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([vehicleId, serviceDate])
  @@index([maintenanceTemplateId])
  @@index([serviceType])
  @@index([maintenanceCategory])
  @@index([createdByUserId])
}

model VehicleMaintenancePartUsage {
  id                  String   @id @default(cuid())
  maintenanceRecordId String
  maintenanceRecord   VehicleMaintenanceRecord @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  inventoryPartId     String?
  inventoryPart       InventoryPart? @relation(fields: [inventoryPartId], references: [id], onDelete: SetNull)
  customPartName      String?
  quantity            Float
  unitCost            Int      @default(0)
  totalCost           Int      @default(0)
  supplierName        String?
  purchasedAt         DateTime?
  notes               String?

  @@index([maintenanceRecordId])
  @@index([inventoryPartId])
}

model InventoryPart {
  id                  String   @id @default(cuid())
  name                String
  sku                 String?  @unique
  category            String?
  brand               String?
  unit                String?
  quantityInStock     Float    @default(0)
  reorderThreshold    Float?
  averageUnitCost     Int?
  defaultSupplierName String?
  isTireRelated       Boolean  @default(false)
  tireBrandModel      String?
  isActive            Boolean  @default(true)
  templateParts       MaintenanceTemplatePart[]
  maintenanceUsages   VehicleMaintenancePartUsage[]
  transactions        InventoryTransaction[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([isActive])
  @@index([category])
  @@index([isTireRelated])
}

model InventoryTransaction {
  id                       String   @id @default(cuid())
  inventoryPartId          String
  inventoryPart            InventoryPart @relation(fields: [inventoryPartId], references: [id], onDelete: Cascade)
  type                     InventoryTransactionType
  quantity                 Float
  unitCost                 Int?
  totalCost                Int?
  relatedVehicleId         String?
  relatedVehicle           Vehicle? @relation(fields: [relatedVehicleId], references: [id], onDelete: SetNull)
  relatedMaintenanceRecordId String?
  relatedMaintenanceRecord VehicleMaintenanceRecord? @relation(fields: [relatedMaintenanceRecordId], references: [id], onDelete: SetNull)
  transactionDate          DateTime
  notes                    String?
  createdByUserId          String?
  createdByUser            AdminUser? @relation("InventoryTransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime @default(now())

  @@index([inventoryPartId, transactionDate])
  @@index([type])
  @@index([relatedVehicleId])
  @@index([relatedMaintenanceRecordId])
  @@index([createdByUserId])
}

model VehicleOdometerLog {
  id              String   @id @default(cuid())
  vehicleId       String
  vehicle         Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  readingKm       Int
  readingDate     DateTime
  source          OdometerLogSource
  notes           String?
  createdByUserId String?
  createdByUser   AdminUser? @relation("VehicleOdometerLogCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([vehicleId, readingDate])
  @@index([source])
  @@index([createdByUserId])
}

model VehicleInsuranceRecord {
  id               String   @id @default(cuid())
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  providerName     String
  policyNumber     String?
  coverageType     String?
  startDate        DateTime
  endDate          DateTime
  premiumAmount    Int?
  paymentFrequency String?
  notes            String?
  isActive         Boolean  @default(true)
  attachments      VehicleAttachment[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([vehicleId, endDate])
  @@index([isActive])
}

model VehicleInspectionRecord {
  id                    String   @id @default(cuid())
  vehicleId             String
  vehicle               Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  inspectionType        String?
  inspectionDate        DateTime
  expiryDate            DateTime?
  passed                Boolean?
  authorityOrVendorName String?
  cost                  Int?
  notes                 String?
  isActive              Boolean  @default(true)
  attachments           VehicleAttachment[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([vehicleId, inspectionDate])
  @@index([expiryDate])
  @@index([isActive])
}

model VehicleAttachment {
  id                 String   @id @default(cuid())
  vehicleId          String?
  vehicle            Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  maintenanceRecordId String?
  maintenanceRecord  VehicleMaintenanceRecord? @relation(fields: [maintenanceRecordId], references: [id], onDelete: Cascade)
  insuranceRecordId  String?
  insuranceRecord    VehicleInsuranceRecord? @relation(fields: [insuranceRecordId], references: [id], onDelete: Cascade)
  inspectionRecordId String?
  inspectionRecord   VehicleInspectionRecord? @relation(fields: [inspectionRecordId], references: [id], onDelete: Cascade)
  fileName           String
  fileUrl            String
  mimeType           String?
  uploadedAt         DateTime @default(now())
  uploadedByUserId   String?
  uploadedByUser     AdminUser? @relation("VehicleAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([maintenanceRecordId])
  @@index([insuranceRecordId])
  @@index([inspectionRecordId])
  @@index([uploadedByUserId])
}

model VehicleUnavailabilityRecord {
  id                     String   @id @default(cuid())
  vehicleId              String
  vehicle                Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  type                   VehicleUnavailabilityType
  startDate              DateTime
  endDate                DateTime?
  reason                 String?
  relatedMaintenanceRecordId String?
  relatedMaintenanceRecord VehicleMaintenanceRecord? @relation(fields: [relatedMaintenanceRecordId], references: [id], onDelete: SetNull)
  createdByUserId        String?
  createdByUser          AdminUser? @relation("VehicleUnavailabilityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([vehicleId, startDate, endDate])
  @@index([type])
  @@index([relatedMaintenanceRecordId])
  @@index([createdByUserId])
}

model VehicleFeature {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  categories  VehicleCategoryFeature[]

  @@index([isActive, sortOrder])
  @@index([name])
}

model VehicleCategoryFeature {
  categoryId   String
  featureId    String
  category     VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  feature      VehicleFeature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@id([categoryId, featureId])
  @@index([featureId])
}

model Booking {
  id                  String    @id @default(cuid())
  categoryId          String
  category            VehicleCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  vehicleId           String?
  vehicle             Vehicle?  @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  customerName        String
  customerEmail       String
  customerPhone       String
  flightNumber        String?
  birthDate           DateTime?
  driverLicenseNumber String?
  licenseExpiryDate   DateTime?
  driverLicenseUrl    String?
  startDate           DateTime
  endDate             DateTime  // treated as exclusive end date for overlap logic
  pickupLocationId    String?
  pickupLocationRef   Location? @relation("PickupLocation", fields: [pickupLocationId], references: [id], onDelete: SetNull)
  dropoffLocationId   String?
  dropoffLocationRef  Location? @relation("DropoffLocation", fields: [dropoffLocationId], references: [id], onDelete: SetNull)
  pickupLocation      String?
  dropoffLocation     String?
  totalAmount         Int       // stored in cents
  status              BookingStatus @default(PENDING)
  bookingCode         String    @unique
  holdExpiresAt       DateTime  @default(dbgenerated("(now() + '02:00:00'::interval)"))
  paymentProofUrl     String?
  paymentReceivedAt   DateTime?
  pickupOdometerKm    Int?
  pickupFuelLevel     Int?
  pickupHasDamage     Boolean   @default(false)
  pickupDamageNotes   String?
  pickupAcceptedBy    String?
  pickupAcceptedAt    DateTime?
  pickupAgentNotes    String?
  deliveredAt         DateTime?
  returnOdometerKm    Int?
  returnFuelLevel     Int?
  returnHasDamage     Boolean   @default(false)
  returnDamageNotes   String?
  returnAcceptedBy    String?
  returnAcceptedAt    DateTime?
  returnAgentNotes    String?
  returnLateCharge    Int       @default(0)
  returnFuelCharge    Int       @default(0)
  returnDamageCharge  Int       @default(0)
  returnedAt          DateTime?
  termsAcceptedAt     DateTime?
  driverLicenseDeleteAfter DateTime?
  driverLicenseDeletedAt DateTime?
  notes               String?
  invoiceUrl          String?
  billingDocumentType BillingDocumentType?
  quickBooksTransferStatus QuickBooksTransferStatus?
  quickBooksDocumentType QuickBooksDocumentType?
  quickBooksCustomerId String?
  quickBooksInvoiceId String?
  quickBooksSalesReceiptId String?
  quickBooksPaymentId String?
  quickBooksLastError String?
  quickBooksSyncRequestedAt DateTime?
  quickBooksSyncedAt DateTime?
  zohoTransferStatus ZohoTransferStatus?
  zohoDocumentType ZohoDocumentType?
  zohoCustomerId String?
  zohoInvoiceId String?
  zohoPaymentId String?
  zohoLastError String?
  zohoSyncRequestedAt DateTime?
  zohoSyncedAt DateTime?
  createdAt           DateTime  @default(now())
  bookingExtras       BookingExtra[]
  bookingDiscount     BookingDiscount?
  inspectionPhotos    BookingInspectionPhoto[]
  review              Review?
  auditLogs           AuditLog[]

  @@index([vehicleId, startDate, endDate])
  @@index([categoryId, startDate, endDate])
  @@index([pickupLocationId])
  @@index([dropoffLocationId])
  @@index([status])
  @@index([bookingCode])
  @@index([createdAt])
  @@index([billingDocumentType])
  @@index([quickBooksTransferStatus])
  @@index([zohoTransferStatus])
  @@index([driverLicenseDeleteAfter, driverLicenseDeletedAt])
  adminUsers AdminUser[]
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @default(now()) @db.Timestamp(6)
}

model Review {
  id           String   @id @default(cuid())
  bookingId    String   @unique
  booking      Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingCode  String
  customerName String
  rating       Int
  comment      String
  isVisible    Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([isVisible, createdAt])
  @@index([bookingCode])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  DECLINED
  CANCELLED
}

enum BillingDocumentType {
  INVOICE
  SALES_RECEIPT
}

enum QuickBooksTransferStatus {
  PENDING
  COMPLETED
  FAILED
}

enum QuickBooksDocumentType {
  INVOICE
  SALES_RECEIPT
  PAYMENT
}

enum ZohoTransferStatus {
  PENDING
  COMPLETED
  FAILED
}

enum ZohoDocumentType {
  INVOICE
  SALES_RECEIPT
  PAYMENT
}

enum InspectionStage {
  PICKUP
  RETURN
}

enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model AuditLog {
  id            String    @id @default(cuid())
  adminUserId   String
  adminUser     AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  action        String
  bookingId     String?
  booking       Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  createdAt     DateTime  @default(now())

  @@index([adminUserId])
  @@index([createdAt])
}

model Notification {
  id              String   @id @default(cuid())
  type            String
  title           String
  message         String
  href            String?
  severity        NotificationSeverity @default(INFO)
  createdByUserId String?
  createdByUser   AdminUser? @relation("NotificationCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([severity])
  @@index([type])
}

enum ExtraPricingType {
  DAILY
  FLAT
}

model Extra {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  pricingType ExtraPricingType @default(FLAT)
  amount      Int
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  bookingExtras BookingExtra[]

  @@index([isActive])
}

model BookingExtra {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extraId    String
  extra      Extra    @relation(fields: [extraId], references: [id], onDelete: Cascade)
  quantity   Int      @default(1)
  lineTotal  Int
  createdAt  DateTime @default(now())

  @@unique([bookingId, extraId])
  @@index([bookingId])
  @@index([extraId])
}

model BookingInspectionPhoto {
  id         String          @id @default(cuid())
  bookingId  String
  booking    Booking         @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  stage      InspectionStage
  imageUrl   String
  createdAt  DateTime        @default(now())

  @@index([bookingId, stage, createdAt])
}

model DiscountCode {
  id          String   @id @default(cuid())
  code        String   @unique
  description String?
  percentage  Int
  isActive    Boolean  @default(true)
  maxUses     Int?
  usedCount   Int      @default(0)
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  bookings    BookingDiscount[]
}

model BookingDiscount {
  id             String       @id @default(cuid())
  bookingId      String       @unique
  booking        Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Restrict)
  percentage     Int
  amount         Int
  createdAt      DateTime     @default(now())

  @@index([discountCodeId])
}
